{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Retail product inventory item at a specific store",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "currentStock": { "type": "number" },
        "minStockThreshold": { "type": "number" },
        "maxStockCapacity": { "type": "number" },
        "unitPrice": { "type": "number" },
        "costPrice": { "type": "number" },
        "unit": { "type": "string" },
        "lastRestocked": { "type": "string", "format": "date-time" },
        "sku": { "type": "string" },
        "storeId": { "type": "string" },
        "supplierId": { "type": "string" },
        "isPerishable": { "type": "boolean" },
        "leadTime": { "type": "number" },
        "totalSpoiled": { "type": "number" }
      },
      "required": ["name", "category", "currentStock", "sku", "storeId", "supplierId"]
    },
    "Store": {
      "title": "Store",
      "description": "Retail store location",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "location": { "type": "string" },
        "warehouseCapacity": { "type": "number" },
        "staffCount": { "type": "number" },
        "demandMultiplier": { "type": "number" }
      },
      "required": ["name", "location", "warehouseCapacity"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Inventory supplier",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "reliability": { "type": "number" },
        "minOrderQuantity": { "type": "number" },
        "defaultLeadTime": { "type": "number" },
        "contactEmail": { "type": "string" }
      },
      "required": ["name", "contactEmail"]
    },
    "SaleRecord": {
      "title": "Sale Record",
      "description": "Historical sale event",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "storeId": { "type": "string" },
        "quantity": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "priceAtSale": { "type": "number" },
        "costAtSale": { "type": "number" }
      },
      "required": ["productId", "storeId", "quantity", "timestamp", "priceAtSale"]
    },
    "InventoryOrder": {
      "title": "Inventory Order",
      "description": "Restock order in transit",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "storeId": { "type": "string" },
        "supplierId": { "type": "string" },
        "quantity": { "type": "number" },
        "unitCost": { "type": "number" },
        "placedAt": { "type": "string", "format": "date-time" },
        "arriveAt": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "delivered", "cancelled"] }
      },
      "required": ["productId", "storeId", "supplierId", "quantity", "placedAt", "arriveAt"]
    },
    "SimulationEvent": {
      "title": "Simulation Event",
      "description": "Active demand impact event",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["competitor", "flashsale", "festival"] },
        "label": { "type": "string" },
        "storeId": { "type": "string" },
        "productId": { "type": "string" },
        "endsAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "label", "storeId", "endsAt"]
    },
    "Alert": {
      "title": "Alert",
      "description": "System or inventory alert",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["low_stock", "out_of_stock", "demand_surge", "system", "spoilage", "anomaly"] },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "productId": { "type": "string" },
        "storeId": { "type": "string" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "read": { "type": "boolean" }
      },
      "required": ["type", "message", "timestamp", "priority", "read"]
    },
    "Forecast": {
      "title": "Forecast",
      "description": "AI generated demand forecast",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "storeId": { "type": "string" },
        "predictedDemand": { "type": "number" },
        "confidenceScore": { "type": "number" },
        "reasoning": { "type": "string" },
        "suggestedRestock": { "type": "number" },
        "forecastDate": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "storeId", "predictedDemand", "forecastDate"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Inventory products"
    },
    "/stores/{storeId}": {
      "schema": "Store",
      "description": "Store locations"
    },
    "/suppliers/{supplierId}": {
      "schema": "Supplier",
      "description": "Inventory suppliers"
    },
    "/sales/{saleId}": {
      "schema": "SaleRecord",
      "description": "Sales history"
    },
    "/orders/{orderId}": {
      "schema": "InventoryOrder",
      "description": "Stock orders"
    },
    "/events/{eventId}": {
      "schema": "SimulationEvent",
      "description": "Simulation events"
    },
    "/alerts/{alertId}": {
      "schema": "Alert",
      "description": "Inventory and system alerts"
    },
    "/forecasts/{forecastId}": {
      "schema": "Forecast",
      "description": "AI demand forecasts"
    }
  }
}
